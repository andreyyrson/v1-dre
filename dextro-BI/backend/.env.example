# Copie para .env e preencha com suas chaves reais
BOMCONTROLE_API_KEY=SuaChaveAqui

# Configurações opcionais
CACHE_TTL_CONTAS=300
CACHE_TTL_EMPRESAS=1800
MAX_PERIODO_DIAS=90
API_RETRY_MAX=3
API_RETRY_DELAY=2.0

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGINS=http://localhost:5173

# Autenticação / JWT (troque o segredo em produção!)
JWT_SECRET=troque-este-segredo-em-producao
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Banco de usuários
DATABASE_URL=sqlite:///./app.db

# Admin inicial (criado no 1º startup se não houver usuários)
ADMIN_USERNAME=admin@dextro
ADMIN_PASSWORD=admin123
